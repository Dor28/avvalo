# Copy to .env for local development. Never commit real secrets.

# Telegram bot
TELEGRAM_TOKEN=replace-with-bot-token

# PostgreSQL / privacy identity
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+asyncpg://avvalo:avvalo@localhost:5432/avvalo
APP_HMAC_SECRET=replace-with-at-least-32-random-characters

# Qwen through a neutral OpenAI-compatible host
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=qwen/qwen-2.5-72b-instruct
LLM_IN_RATE_PER_M=0
LLM_OUT_RATE_PER_M=0

# Google Cloud Vision (T8)
GOOGLE_APPLICATION_CREDENTIALS=
OCR_MIN_CONFIDENCE=0.5

# Consent, limits, and timeouts
NOTICE_VERSION=2026-06-24-v1
DAILY_LIMIT_FAMILY_SHIELD=5
DAILY_LIMIT_SELLER_GUARD=20
LLM_TIMEOUT_S=30
OCR_TIMEOUT_S=30
MAX_OUTPUT_TOKENS=600
OPERATOR_ALERT_CHAT_ID=

# Anonymous web channel (T13)
WEB_ENABLED=false
WEB_HOST=0.0.0.0
WEB_PORT=8000
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
WEB_SESSION_SECRET=replace-with-at-least-32-random-characters
WEB_DAILY_LIMIT=5
