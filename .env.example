# Copy to .env for local development. Never commit real secrets.

# Telegram bot
TELEGRAM_TOKEN=replace-with-bot-token

# PostgreSQL / privacy identity
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+asyncpg://avvalo:avvalo@localhost:5432/avvalo
APP_HMAC_SECRET=replace-with-at-least-32-random-characters

# Qwen through a neutral OpenAI-compatible host
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=qwen/qwen-2.5-72b-instruct
LLM_IN_RATE_PER_M=0
LLM_OUT_RATE_PER_M=0

# Google Cloud Vision (T8)
GOOGLE_APPLICATION_CREDENTIALS=
OCR_MIN_CONFIDENCE=0.5

# Consent, limits, and timeouts
NOTICE_VERSION=2026-07-07-v2
DAILY_CHECK_LIMIT=5
LLM_TIMEOUT_S=30
OCR_TIMEOUT_S=30
MAX_OUTPUT_TOKENS=600
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
KNOWLEDGE_ROUTER_ENABLED=false
KNOWLEDGE_ROUTER_BASE_URL=
KNOWLEDGE_ROUTER_API_KEY=
KNOWLEDGE_ROUTER_MODEL=
KNOWLEDGE_ROUTER_TIMEOUT_S=10
URL_REPUTATION_ENABLED=false
URLHAUS_FEED_URL=https://urlhaus.abuse.ch/downloads/csv_online/
OPENPHISH_FEED_URL=https://openphish.com/feed.txt
URL_FEEDS_REFRESH_HOURS=12
KNOWLEDGE_GAP_DEFAULT_DAYS=7
KNOWLEDGE_UNAVAILABLE_ALERT_THRESHOLD=0.20
KNOWLEDGE_UNAVAILABLE_ALERT_WINDOW_MINUTES=30
OPERATOR_ALERT_CHAT_ID=
OPERATOR_ALERT_DEBOUNCE_S=900
# Legacy cleanup only; new story submissions are disabled.
STORY_REJECTED_RETENTION_DAYS=30

# Error tracking — optional; leave SENTRY_DSN blank to disable Sentry entirely
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Anonymous web channel (T13)
WEB_ENABLED=false
WEB_HOST=0.0.0.0
WEB_PORT=8000
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
WEB_SESSION_SECRET=replace-with-at-least-32-random-characters
WEB_DAILY_LIMIT=5
