# ─────────────────────────────────────────────────────────────────────────────
# Avvalo — PRODUCTION environment.
#
#   cp deploy/env.prod.example .env      # at the repo root, next to docker-compose.prod.yml
#   chmod 600 .env                       # owner-read/write only
#
# Never commit this file. Generate every secret on the server (see commands below).
# ─────────────────────────────────────────────────────────────────────────────

# === Container image (GHCR) ==================================================
# Which image tag the stack runs. The CI deploy job rewrites this on every deploy
# (deploy/remote-update.sh) to the just-built `sha-<commit>` tag. A mutable
# `latest` fallback is deliberately not accepted; use a prior sha tag to roll back.
IMAGE_TAG=sha-replace-with-built-commit

# === Telegram bot ============================================================
# Create one bot with @BotFather.
TELEGRAM_TOKEN=replace-with-bot-token

# === PostgreSQL ==============================================================
# Strong DB password:   openssl rand -base64 36
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# App connection string. Host is the compose service name `db`.
DATABASE_URL=postgresql+asyncpg://avvalo:replace-with-a-strong-database-password@db:5432/avvalo

# === Privacy identity secrets (STABLE — never rotate casually) ===============
# HMAC key for pseudonymous user keys. Rotating it changes every user's key,
# which orphans consent rows and resets rate limits. Generate ONCE and keep it.
#   openssl rand -hex 32
APP_HMAC_SECRET=replace-with-64-hex-characters
# Signs the anonymous web session cookie. Same caution as above.
#   openssl rand -hex 32
WEB_SESSION_SECRET=replace-with-64-hex-characters
# Founder-only editorial post admin. Leave blank to disable /admin completely.
#   openssl rand -hex 32
ADMIN_ACCESS_KEY=

# === LLM (Qwen via a neutral OpenAI-compatible host) =========================
# Choose a host offering a DPA + no-retention / no-training.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=qwen/qwen-2.5-72b-instruct
# $ per 1M tokens, from the host's pricing — used for cost accounting.
LLM_IN_RATE_PER_M=0
LLM_OUT_RATE_PER_M=0
LLM_TIMEOUT_S=30
MAX_OUTPUT_TOKENS=600
# Optional second OpenAI-compatible provider used only when the primary fails.
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
KNOWLEDGE_ROUTER_ENABLED=false
KNOWLEDGE_ROUTER_BASE_URL=
KNOWLEDGE_ROUTER_API_KEY=
KNOWLEDGE_ROUTER_MODEL=
KNOWLEDGE_ROUTER_TIMEOUT_S=10
URL_REPUTATION_ENABLED=false
URLHAUS_FEED_URL=https://urlhaus.abuse.ch/downloads/csv_online/
OPENPHISH_FEED_URL=https://openphish.com/feed.txt
URL_FEEDS_REFRESH_HOURS=12
KNOWLEDGE_GAP_DEFAULT_DAYS=7
KNOWLEDGE_UNAVAILABLE_ALERT_THRESHOLD=0.20
KNOWLEDGE_UNAVAILABLE_ALERT_WINDOW_MINUTES=30

# === OCR (Google Cloud Vision) ===============================================
OCR_PROVIDER=gcv
# Path INSIDE the container — must match the read-only mount in
# docker-compose.prod.yml (./secrets/gcv.json -> /run/secrets/gcv.json).
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcv.json
OCR_MIN_CONFIDENCE=0.5
OCR_TIMEOUT_S=30

# === Consent, limits, alerts =================================================
NOTICE_VERSION=2026-07-22-v3
DAILY_LIMIT_FAMILY=5
# Telegram chat id that receives debounced technical error alerts.
# Get it from @userinfobot.
OPERATOR_ALERT_CHAT_ID=
OPERATOR_ALERT_DEBOUNCE_S=900

# === Web channel =============================================================
# Set true to serve the anonymous web app behind nginx. false = bot-only.
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Cloudflare Turnstile keys (required to allow image upload on the web).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
WEB_DAILY_LIMIT=5
# Mark the session cookie Secure — keep true in production (TLS terminates at
# nginx). Only set false for plain-HTTP local development.
WEB_COOKIE_SECURE=true

# === Reverse proxy / TLS (consumed by docker-compose.prod.yml, nginx + certbot)
# AVVALO_DOMAIN is the public hostname nginx serves and certbot issues a cert
# for. ACME_EMAIL receives Let's Encrypt expiry notices (recommended; leave
# blank to register without an email). Bootstrap the first cert once with
# deploy/nginx/init-letsencrypt.sh.
AVVALO_DOMAIN=avvalo.example.com
ACME_EMAIL=you@example.com
